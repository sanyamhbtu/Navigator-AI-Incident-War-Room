# ── REQUIRED ────────────────────────────────────────────────────────────────
# Get a free key at console.groq.com → API Keys
GROQ_API_KEY=

# ── OPTIONAL (everything below has sensible defaults) ───────────────────────

# Server
PORT=3001
NODE_ENV=development

# Shared secret between frontend proxy and backend. Default: "dev-key"
# Must match BACKEND_API_KEY in navigator-ui/.env.local
INTERNAL_API_KEY=dev-key

# Groq model. Default: llama-3.3-70b-versatile (best reasoning, 12K TPM)
# Other choices: meta-llama/llama-4-scout-17b-16e-instruct, openai/gpt-oss-120b
GROQ_MODEL=llama-3.3-70b-versatile

# ── LIVE CORAL (only if you have the CLI + sources installed) ──────────────
# CORAL_LIVE=true switches from fixtures to the real `coral sql` CLI.
# Leave unset for demos — the backend ships with realistic fixture data.
# CORAL_LIVE=true

# ── REAL APIS (only used if you wire live overlay on /api/incidents) ────────
# Skip these for the demo — routes handle missing creds gracefully.
# PAGERDUTY_API_KEY=
# DATADOG_API_KEY=
# DATADOG_APP_KEY=
# GITHUB_TOKEN=
# SLACK_BOT_TOKEN=
# SENTRY_AUTH_TOKEN=
# LINEAR_API_KEY=
